# Copy this file to .env and fill in your values

# Shopify
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token

# Gmail SMTP (App Password — not your regular password)
# How to get: myaccount.google.com > Security > App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
# Local Mac dev: leave unset — SQLite is used automatically
# Render / production: set to your Supabase connection string
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
